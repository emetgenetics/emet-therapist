generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── User Management ──────────────────────────────────────────────

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  emailVerified     DateTime?
  name              String?
  image             String?
  
  // Auth
  passwordHash      String?  @map("password_hash")
  mfaSecret         String?  @map("mfa_secret")
  mfaEnabled        Boolean  @default(false) @map("mfa_enabled")
  
  // Profile
  phone             String?
  emergencyContact  String?  @map("emergency_contact")
  
  // Status
  isActive          Boolean  @default(true) @map("is_active")
  isAdmin           Boolean  @default(false) @map("is_admin")
  lastLoginAt       DateTime? @map("last_login_at")
  
  // Relations
  therapySessions   TherapySession[]
  accounts          Account[]
  authenticators    Authenticator[]
  nextAuthSessions  Session[]
  consentRecords    ConsentRecord[]
  blsConfigurations BLSConfiguration[]
  auditLogs         AuditLog[]
  
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ─── NextAuth Models ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Authenticator {
  credentialID         String  @unique @map("credential_id")
  userId               String  @map("user_id")
  providerAccountId    String  @map("provider_account_id")
  credentialPublicKey  String  @map("credential_public_key")
  counter              Int
  credentialDeviceType String  @map("credential_device_type")
  credentialBackedUp   Boolean @map("credential_backed_up")
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
  @@map("authenticators")
}

// ─── Therapy Sessions ─────────────────────────────────────────────

model TherapySession {
  id                String        @id @default(cuid())
  userId            String        @map("user_id")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // State machine tracking
  currentState      SessionState  @default(PRE_FLIGHT) @map("current_state")
  stateHistory      Json[]        @default([]) @map("state_history")
  
  // Session metadata
  sessionGoals      String?       @map("session_goals")
  therapistNotes    String?       @map("therapist_notes")
  distressLevel     Int?          @map("distress_level")
  
  // BLS config snapshot
  blsConfig         Json?         @map("bls_config")
  
  // Timestamps
  startedAt         DateTime      @default(now()) @map("started_at")
  endedAt           DateTime?     @map("ended_at")
  
  // Relations
  transcripts       Transcript[]
  events            SessionEvent[]
  
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@index([userId, currentState])
  @@index([startedAt])
  @@map("therapy_sessions")
}

enum SessionState {
  PRE_FLIGHT
  INTAKE
  DESENSITIZATION
  PIVOT
  RECONNECTION
  INTEGRATION
  EMERGENCY_GROUNDING
  COMPLETED
  ABANDONED
}

// ─── Session Transcripts ──────────────────────────────────────────

model Transcript {
  id            String           @id @default(cuid())
  sessionId     String           @map("session_id")
  session       TherapySession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  timestamp     DateTime         @default(now())
  speaker       TranscriptSpeaker
  content       String           @db.Text
  
  // Metadata
  wordCount     Int              @default(0) @map("word_count")
  durationMs    Int?             @map("duration_ms")
  
  createdAt     DateTime         @default(now()) @map("created_at")

  @@index([sessionId, timestamp])
  @@map("transcripts")
}

enum TranscriptSpeaker {
  CLIENT
  AI_THERAPIST
  SYSTEM
}

// ─── Session Events ───────────────────────────────────────────────

model SessionEvent {
  id            String           @id @default(cuid())
  sessionId     String           @map("session_id")
  session       TherapySession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId        String           @map("user_id")
  
  eventType     SessionEventType  @map("event_type")
  fromState     SessionState?    @map("from_state")
  toState       SessionState?    @map("to_state")
  metadata      Json?
  
  createdAt     DateTime         @default(now()) @map("created_at")

  @@index([sessionId, createdAt])
  @@index([userId])
  @@map("session_events")
}

enum SessionEventType {
  STATE_TRANSITION
  BLS_STARTED
  BLS_STOPPED
  DISTRESS_DETECTED
  EMERGENCY_TRIGGERED
  EMERGENCY_RESOLVED
  VOICE_SESSION_STARTED
  VOICE_SESSION_ENDED
  SESSION_PAUSED
  SESSION_RESUMED
}

// ─── BLS Configurations ───────────────────────────────────────────

model BLSConfiguration {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name                String
  
  // Visual BLS settings
  visualPattern       String   @default("horizontal") @map("visual_pattern")
  visualSpeed         Int      @default(60) @map("visual_speed")
  visualIntensity     Float    @default(0.7) @map("visual_intensity")
  visualColorPrimary  String   @default("#8B5CF6") @map("visual_color_primary")
  visualColorSecondary String  @default("#C4B5FD") @map("visual_color_secondary")
  
  // Auditory BLS settings
  auditoryFrequency   Int      @default(440) @map("auditory_frequency")
  auditoryVolume      Float    @default(0.15) @map("auditory_volume")
  auditoryWaveform    String   @default("sine") @map("auditory_waveform")
  
  isDefault           Boolean  @default(false) @map("is_default")
  
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("bls_configurations")
}

// ─── Consent Records ──────────────────────────────────────────────

model ConsentRecord {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  consentType   String   @map("consent_type")
  granted       Boolean
  version       String
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId, consentType])
  @@map("consent_records")
}

// ─── App Settings ─────────────────────────────────────────────────

model AppSettings {
  id              String   @id @default(cuid())
  key             String   @unique
  value           Json
  description     String?
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// ─── Audit Logs ───────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(cuid())
  userId        String?  @map("user_id")
  user          User?    @relation(fields: [userId], references: [id])
  
  action        String
  resourceType  String   @map("resource_type")
  resourceId    String?  @map("resource_id")
  
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  metadata      Json?
  
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action, resourceType])
  @@map("audit_logs")
}
